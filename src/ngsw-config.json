{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-condiciones",
      "urls": ["/api/v2/condiciones", "/api/v2/puertos"],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "30m",
        "timeout": "10s",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-historial",
      "urls": ["/api/v2/historial", "/api/v2/estadisticas", "/api/v2/rankings"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "5m",
        "timeout": "15s",
        "strategy": "freshness"
      }
    }
  ]
}
